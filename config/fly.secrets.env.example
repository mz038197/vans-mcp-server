# Copy to %USERPROFILE%\.vans-mcp-server\fly.secrets.env (UTF-8 without BOM)
# Then: powershell -ExecutionPolicy Bypass -File scripts\deploy-fly.ps1

# Same Neon connection string as vans-coding-router (API key verification + mcp_usage + oauth tokens).
DATABASE_URL=

# Google OAuth (Calendar connect — separate from portal/dungeon login).
# Reuse the same OAuth Client as router if desired; add redirect URI:
#   https://mcp.vanscoding.com/connect/google/callback
#   http://127.0.0.1:8080/connect/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# HMAC for connect-link state (can differ from router SESSION_SECRET).
SESSION_SECRET=

# Fernet key for encrypting Google refresh/access tokens and Discord bot tokens at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OAUTH_TOKEN_ENCRYPTION_KEY=

# Optional override (default: {PUBLIC_URL}/connect/google/callback)
# GOOGLE_OAUTH_REDIRECT_URI=https://mcp.vanscoding.com/connect/google/callback

# Discord classroom portal: per-student bot tokens are stored encrypted in Neon
# (provider=discord_bot). There is no shared DISCORD_BOT_TOKEN secret.
# Set the classroom guild id in fly.toml [env] as DISCORD_GUILD_ID (not a secret).

# PUBLIC_URL lives in fly.toml [env] — do not set it as a Fly secret.

# Local/dev only — never set this in production Fly secrets.
# MCP_DEV_BYPASS_KEY=vcr_sk_dev_local_only
